# Copy this file to ".env.local" for local dev and fill in the values.
# These two values are SAFE to expose in a browser (the anon key is
# designed to be public and is protected by Row Level Security).
#
# Find them in: Supabase Dashboard -> Project Settings -> API
#   - "Project URL"      -> VITE_SUPABASE_URL
#   - "anon" "public" key -> VITE_SUPABASE_ANON_KEY
#
# NEVER put the service_role / secret key here or anywhere in the frontend.

VITE_SUPABASE_URL=https://klkfbluxycjpzdomcadu.supabase.co
VITE_SUPABASE_ANON_KEY=PASTE_YOUR_ANON_PUBLIC_KEY_HERE
